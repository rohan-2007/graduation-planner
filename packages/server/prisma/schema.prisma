datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output = "../generated/prisma"
}

enum Semester {
  SPRING
  AUTUMN
  SUMMER
}

model User {
  id                  Int         @id @default(autoincrement())
  username            String
  password            String
  school              String
  major               String      @default("")
  minor               String      @default("")
  gradYear            Int
  gradSemester        Semester    @default(SPRING)
  completedCourses    String[]    @default([])
  currentCourses      String[]    @default([])
  requiredCourses     String[]    @default([])
}

model Course {
  id                  Int        @id @default(autoincrement())
  code                String     @unique  
  name                String
  credits             Float
  school              String
  prerequisiteCodes   String[]
}

model Conversation {
  id                  String    @id @default(uuid())
  studentId           Int
  title               String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}